{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ssh-manager inventory",
  "type": "object",
  "required": [
    "version",
    "keys"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "keys": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "profile",
          "path"
        ],
        "properties": {
          "profile": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "comment": {
            "type": [
              "string",
              "null"
            ]
          },
          "created": {
            "type": [
              "string",
              "null"
            ]
          },
          "rotate_after_days": {
            "type": "integer"
          },
          "expires_on": {
            "type": [
              "string",
              "null"
            ]
          },
          "deployments": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "target",
                "method"
              ],
              "properties": {
                "target": {
                  "type": "string"
                },
                "method": {
                  "type": "string"
                },
                "date": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "verified": {
                  "type": "boolean"
                }
              }
            }
          }
        }
      }
    }
  },
  "additionalProperties": false
}
