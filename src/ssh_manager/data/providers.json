{
  "version": 1,
  "_comment": "Provider INSTANCES (deploy targets for a public key). 'kind' selects the adapter; github/gitlab automate via gh/glab (cloud + enterprise/self-hosted via 'host'); every other VCS works via the universal web-panel/manual path with the right keys URL. To add an instance: copy an *-enterprise / *-self-hosted entry, set 'host' + 'token_env', and reference its name from a host's \"provider\".",
  "providers": {
    "github":              {"category": "vcs",    "kind": "github",           "host": "github.com",         "api": "https://api.github.com", "cli": "gh",   "token_env": "GH_TOKEN"},
    "github-enterprise":   {"category": "vcs",    "kind": "github",           "host": "github.example.com", "api": "https://github.example.com/api/v3", "cli": "gh", "token_env": "GHE_TOKEN"},
    "gitlab":              {"category": "vcs",    "kind": "gitlab",           "host": "gitlab.com",         "cli": "glab", "token_env": "GLAB_TOKEN"},
    "gitlab-self-hosted":  {"category": "vcs",    "kind": "gitlab",           "host": "gitlab.example.com", "cli": "glab", "token_env": "GLAB_TOKEN"},
    "bitbucket":           {"category": "vcs",    "kind": "bitbucket",        "host": "bitbucket.org"},
    "bitbucket-server":    {"category": "vcs",    "kind": "bitbucket-server", "host": "bitbucket.example.com"},
    "gitea":               {"category": "vcs",    "kind": "gitea",            "host": "gitea.com"},
    "gitea-self-hosted":   {"category": "vcs",    "kind": "gitea",            "host": "gitea.example.com"},
    "codeberg":            {"category": "vcs",    "kind": "codeberg",         "host": "codeberg.org"},
    "forgejo":             {"category": "vcs",    "kind": "forgejo",          "host": "forgejo.example.com"},
    "gogs":                {"category": "vcs",    "kind": "gogs",             "host": "gogs.example.com"},
    "sourcehut":           {"category": "vcs",    "kind": "sourcehut",        "host": "meta.sr.ht"},
    "azure-devops":        {"category": "vcs",    "kind": "azure-devops",     "host": "dev.azure.com"},
    "aws-codecommit":      {"category": "vcs",    "kind": "aws-codecommit"},
    "digitalocean":        {"category": "vps",    "kind": "digitalocean",     "token_env": "DIGITALOCEAN_TOKEN"},
    "vultr":               {"category": "vps",    "kind": "vultr",            "token_env": "VULTR_API_KEY"},
    "hetzner":             {"category": "vps",    "kind": "hetzner",          "token_env": "HCLOUD_TOKEN"},
    "linode":              {"category": "vps",    "kind": "linode",           "token_env": "LINODE_TOKEN"},
    "scaleway":            {"category": "vps",    "kind": "scaleway",         "token_env": "SCW_SECRET_KEY"},
    "example-rest":        {"category": "vps",    "kind": "rest",             "token_env": "EXAMPLE_TOKEN",
                            "rest": {"base_url": "https://api.example.com/v1", "list_path": "/ssh_keys",
                                     "list_field": "ssh_keys", "id_field": "id", "name_field": "name",
                                     "public_key_field": "public_key", "create_path": "/ssh_keys",
                                     "delete_path": "/ssh_keys/{id}", "auth_header_name": "Authorization",
                                     "auth_header_prefix": "Bearer "}},
    "ploi":                {"category": "panel",  "kind": "web-panel",        "manage_url": "https://ploi.io/servers"},
    "forge":               {"category": "panel",  "kind": "web-panel",        "manage_url": "https://forge.laravel.com/servers"},
    "cpanel":              {"category": "panel",  "kind": "web-panel"},
    "generic-ssh":         {"category": "server", "kind": "ssh",              "method": "ssh-copy-id"},
    "manual":              {"category": "generic","kind": "web-panel"}
  }
}
